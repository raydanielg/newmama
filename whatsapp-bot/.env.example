# ============================================================
# 🤖 MamaCare WhatsApp Bot - Environment Configuration
# ============================================================
# Copy this file to .env and update the values
# DO NOT commit .env to version control!
# ============================================================

# ===============================
# 🌐 Server Configuration
# ===============================
# Port to run the bot server (default: 3000)
PORT=3000

# Environment: development | production
NODE_ENV=production

# ===============================
# 🔐 API Security (IMPORTANT!)
# ===============================
# Generate a strong API key (use: openssl rand -hex 32)
# This key must match WHATSAPP_API_KEY in your Laravel .env
API_KEY=your_strong_secret_api_key_here_change_this

# CORS - Allowed origins (comma-separated)
# Add your Laravel app domain here
ALLOWED_ORIGINS=http://localhost,http://localhost:8000,https://your-domain.com

# ===============================
# 🛡️ Rate Limiting
# ===============================
# Time window in milliseconds (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window (30 requests per minute)
RATE_LIMIT_MAX_REQUESTS=30

# ===============================
# 💬 Message Settings
# ===============================
# Delay between messages in milliseconds (3000 = 3 seconds)
# Increase to avoid WhatsApp bans
DEFAULT_DELAY_MS=3000

# Max retry attempts for failed messages
MAX_RETRIES=3

# Delay between retries in milliseconds
RETRY_DELAY_MS=5000

# ===============================
# 📝 Logging
# ===============================
# Log levels: error | warn | info | debug
LOG_LEVEL=info

# Log file path (absolute or relative)
# For VPS: /www/wwwroot/mamacare-bot/logs/bot.log
# For local: logs/whatsapp-bot.log
LOG_FILE=logs/whatsapp-bot.log

# ===============================
# 💾 Session Storage
# ===============================
# Path to store WhatsApp session data
# For VPS: /www/wwwroot/mamacare-bot/.wwebjs_auth
# For local: ./.wwebjs_auth
SESSION_PATH=./.wwebjs_auth

# ===============================
# 🔗 MamaCare Laravel Integration
# ===============================
# Your Laravel app URL (for webhooks)
MAMACARE_BASE_URL=https://your-laravel-domain.com

# API key for Laravel authentication (must match Laravel .env)
MAMACARE_API_KEY=your_laravel_webhook_secret_key

# ===============================
# 🌐 Webhook URLs (Optional)
# ===============================
# Endpoint for message status updates
WEBHOOK_STATUS_URL=/api/webhooks/whatsapp-status

# Endpoint for incoming messages
WEBHOOK_INCOMING_URL=/api/webhooks/whatsapp-incoming

# ===============================
# 🔧 Puppeteer/Chrome Settings (Optional)
# ===============================
# Path to Chrome executable (auto-detected if not set)
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux: /usr/bin/google-chrome
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_EXECUTABLE_PATH=

# Additional Puppeteer arguments (comma-separated)
# Use for VPS with limited resources
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# ===============================
# 📱 WhatsApp Settings (Optional)
# ===============================
# Auto-reply enabled: true | false
AUTO_REPLY_ENABLED=true

# Admin phone for notifications (with country code)
ADMIN_PHONE=+2557XXXXXXXX

# ===============================
# 🚨 Emergency Contacts (Optional)
# ===============================
# Emergency numbers for alerts
EMERGENCY_NUMBER_1=114
EMERGENCY_NUMBER_2=112

# ============================================================
# 📖 EXAMPLES
# ============================================================
#
# LOCAL DEVELOPMENT:
# -----------------
# NODE_ENV=development
# PORT=3000
# API_KEY=dev_key_123
# ALLOWED_ORIGINS=http://localhost,http://localhost:8000
# MAMACARE_BASE_URL=http://localhost:8000
# LOG_FILE=logs/whatsapp-bot.log
# SESSION_PATH=./.wwebjs_auth
#
# VPS PRODUCTION:
# --------------
# NODE_ENV=production
# PORT=3000
# API_KEY=prod_secure_key_abc123xyz
# ALLOWED_ORIGINS=https://mamacare.ai,https://www.mamacare.ai
# MAMACARE_BASE_URL=https://mamacare.ai
# LOG_FILE=/www/wwwroot/mamacare-bot/logs/bot.log
# SESSION_PATH=/www/wwwroot/mamacare-bot/.wwebjs_auth
#
