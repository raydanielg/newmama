# ============================================================
# 🤰 MamaCare AI - Laravel Environment Configuration
# ============================================================
# Copy this file to .env and update the values
# DO NOT commit .env to version control!
# ============================================================

# ===============================
# 🌐 Application Settings
# ===============================
APP_NAME="MamaCare AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Localization
APP_LOCALE=sw
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ===============================
# 🔐 Security Settings
# ===============================
BCRYPT_ROUNDS=12

# ===============================
# 📝 Logging Configuration
# ===============================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===============================
# 🗄️ Database Configuration
# ===============================
# SQLite (Default for local development)
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# MySQL (Production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=mamacare
# DB_USERNAME=root
# DB_PASSWORD=

# PostgreSQL (Alternative)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=mamacare
# DB_USERNAME=root
# DB_PASSWORD=

# ===============================
# 💾 Session Configuration
# ===============================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ===============================
# 🔄 Cache Configuration
# ===============================
CACHE_STORE=database
# CACHE_PREFIX=

# ===============================
# 📡 Broadcasting & Queue
# ===============================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ===============================
# ⚡ Memcached (Optional)
# ===============================
MEMCACHED_HOST=127.0.0.1

# ===============================
# 🔴 Redis Configuration
# ===============================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===============================
# 📧 Mail Configuration
# ===============================
# Log (Development)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

# SMTP (Production)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your_username
# MAIL_PASSWORD=your_password
# MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS="hello@mamacare.ai"
MAIL_FROM_NAME="${APP_NAME}"

# ===============================
# ☁️ AWS S3 (Optional)
# ===============================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===============================
# 🔑 Vite / Frontend
# ===============================
VITE_APP_NAME="${APP_NAME}"

# ============================================================
# 🤖 MamaCare WhatsApp Integration
# ============================================================
WHATSAPP_ENABLED=true
WHATSAPP_BOT_URL=http://localhost:3000
WHATSAPP_API_KEY=your_secret_api_key_here_change_this
WHATSAPP_TIMEOUT=30
WHATSAPP_DEFAULT_DELAY=3000
WHATSAPP_MAX_RETRIES=3

# WhatsApp Webhook URLs (Auto-generated if not set)
# WHATSAPP_WEBHOOK_STATUS_URL=/api/webhooks/whatsapp-status
# WHATSAPP_WEBHOOK_INCOMING_URL=/api/webhooks/whatsapp-incoming

# ===============================
# 🩺 Health & Pregnancy Settings
# ===============================
# Default pregnancy reminder schedule (weeks)
PREGNANCY_WEEKLY_REMINDERS=4,8,12,16,20,24,28,32,36,38,40

# High-risk alert thresholds
BP_SYSTOLIC_THRESHOLD=140
BP_DIASTOLIC_THRESHOLD=90
WEIGHT_GAIN_MAX_WEEKLY_KG=2

# ===============================
# 🚨 Emergency Settings
# ===============================
EMERGENCY_HOTLINE_1=114
EMERGENCY_HOTLINE_2=112
EMERGENCY_HOTLINE_3=999

# SMS Gateway (Optional - for fallback SMS)
# SMS_GATEWAY_URL=
# SMS_GATEWAY_API_KEY=
# SMS_GATEWAY_SENDER_ID=MamaCare

# ===============================
# 🔔 Notification Settings
# ===============================
# Minutes before appointment to send reminder
APPOINTMENT_REMINDER_MINUTES=1440

# Daily reminder time (24-hour format)
DAILY_REMINDER_TIME=09:00

# ===============================
# 🔐 Google OAuth (Optional)
# ===============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=/auth/google/callback

# ===============================
# 🍎 Apple Sign In (Optional)
# ===============================
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URL=/auth/apple/callback

# ===============================
# 📊 Analytics (Optional)
# ===============================
# GOOGLE_ANALYTICS_ID=
# FACEBOOK_PIXEL_ID=

# ============================================================
# 📖 EXAMPLES
# ============================================================
#
# LOCAL DEVELOPMENT:
# -----------------
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://localhost
# DB_CONNECTION=sqlite
# WHATSAPP_BOT_URL=http://localhost:3000
#
# VPS PRODUCTION:
# --------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://mamcareai.co.tz
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_DATABASE=mamacare
# DB_USERNAME=mamacare_user
# DB_PASSWORD=secure_password_here
# WHATSAPP_BOT_URL=https://bot.mamcareai.co.tz
# WHATSAPP_API_KEY=secure_api_key_here
#
# ============================================================
